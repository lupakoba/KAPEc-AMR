params {

    // Input
    input = 'data/*_{R1,R2}.fastq.gz'

    // Contenedor Kraken2 (actualizado)
    kraken2_docker = 'quay.io/biocontainers/kraken2:2.17.1--pl5321h077b44d_0'

    // Base de datos local de Kraken2
    kraken2_db = './db/kraken_db'

    // Número de threads para Kraken2
    kraken2_threads = 4
}

docker {
    enabled = true
}